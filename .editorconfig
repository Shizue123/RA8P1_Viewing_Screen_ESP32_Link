# EditorConfig is awesome: https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{c,h,cpp,hpp,ino}]
indent_size = 4

[*.{md,markdown}]
trim_trailing_whitespace = false
max_line_length = off

[*.{yml,yaml,json}]
indent_size = 2

[*.{sh,ps1}]
indent_size = 4

[Makefile,makefile,*.mk]
indent_style = tab

[*.ld]
indent_size = 4

[*.{xml,html,css}]
indent_size = 2
