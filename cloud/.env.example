APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
# Legacy engineering API only. The public web application never uses this token.
API_TOKEN=

AUTH_DB_PATH=runtime/web_auth.sqlite3
AUTH_SESSION_TTL_HOURS=24
AUTH_COOKIE_NAME=embedded_agent_session
WEB_HARDWARE_CONTROL_ENABLED=false
WEB_HARDWARE_CONTROL_ROLES=admin
WEB_HARDWARE_WAIT_FOR_ACK=false
QQBOT_ENABLED=false
QQBOT_APP_ID=
QQBOT_APP_SECRET=
QQBOT_HARDWARE_CONTROL_ENABLED=false
QQBOT_ALLOW_GROUP_COMMANDS=false
QQBOT_ALLOWED_USER_OPENIDS=
QQBOT_ALLOWED_GROUP_OPENIDS=
AUTOMATION_TASK_DB_PATH=runtime/automation_tasks.sqlite3

HERMES_GATEWAY_URL=http://127.0.0.1:8642
HERMES_GATEWAY_API_KEY=

MQTT_BROKER_URL=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_SCRIPT_SECRET=
MQTT_TLS_ENABLED=false
MQTT_CA_CERT_PATH=
MQTT_CLIENT_ID=embedded-agent-cloud-dev
MQTT_SUBSCRIBER_CLIENT_ID=embedded-agent-cloud-state-subscriber
MQTT_ENABLED=false
DEPLOY_ACK_TIMEOUT_SEC=5
API_RATE_LIMIT_WINDOW_SEC=60
API_RATE_LIMIT_MAX_REQUESTS=120
API_DEPLOY_RATE_LIMIT_MAX_REQUESTS=20

LLM_PROVIDER=template
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
HERMES_MODEL=deepseek/deepseek-v4-pro
ASR_PROVIDER=mock
ASR_MODEL=gpt-4o-mini-transcribe

DEVICE_ID=ra8p1_demo_001
DEVICE_REGISTRY_DB_PATH=runtime/device_registry.sqlite3
# Optional bootstrap secret for POST /devices/register. Keep empty only for local/dev tests.
DEVICE_REGISTRATION_SECRET=
LOG_LEVEL=INFO
LOG_DB_PATH=:temp:
