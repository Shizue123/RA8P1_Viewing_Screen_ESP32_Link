# Add inputs and outputs from these tool invocations to the build variables 
SECONDARY_FLASH += \
RA8P1_Viewing_Screen_ESP32_Link.srec \

SECONDARY_SIZE += \
RA8P1_Viewing_Screen_ESP32_Link.siz \


# All Target
all: RA8P1_Viewing_Screen_ESP32_Link.elf secondary-outputs

# Tool invocations
RA8P1_Viewing_Screen_ESP32_Link.elf: $(OBJS) $(USER_OBJS) $(LINKER_SCRIPT)
	$(file > RA8P1_Viewing_Screen_ESP32_Link.elf.in,-mthumb -mfloat-abi=hard -mcpu=cortex-m85+nopacbti -O2 -fmessage-length=0 -fsigned-char -ffunction-sections -fdata-sections -fno-strict-aliasing -Wunused -Wuninitialized -Wall -Wextra -Wmissing-declarations -Wconversion -Wpointer-arith -Wshadow -Wlogical-op -Waggregate-return -Wfloat-equal -g -T "fsp.ld" -Xlinker --gc-sections -L "D:\\Renesas-Workspace\\RA8P1_Viewing_Screen_ESP32_Link/script" -Wl,-Map,"RA8P1_Viewing_Screen_ESP32_Link.map" --specs=nano.specs -o "RA8P1_Viewing_Screen_ESP32_Link.elf" -Wl,--start-group $(OBJS) $(USER_OBJS) $(LIBS) -Wl,--end-group)
	@echo Building target: $@ && arm-none-eabi-gcc @"RA8P1_Viewing_Screen_ESP32_Link.elf.in"
RA8P1_Viewing_Screen_ESP32_Link.srec: RA8P1_Viewing_Screen_ESP32_Link.elf
	arm-none-eabi-objcopy -O srec "RA8P1_Viewing_Screen_ESP32_Link.elf"  "RA8P1_Viewing_Screen_ESP32_Link.srec"
RA8P1_Viewing_Screen_ESP32_Link.siz: RA8P1_Viewing_Screen_ESP32_Link.elf
	arm-none-eabi-size --format=berkeley "RA8P1_Viewing_Screen_ESP32_Link.elf"
# Other Targets
clean:
	-$(file > clean_file.tmp,  $(JMP_DEPS)  $(FSY_DEPS)  $(C_UPPER_DEPS)  $(SECONDARY_SIZE)  $(SRC_UPPER_DEPS)  $(P_UPPER_DEPS)  $(S_DEPS)  $(PP_UPPER_DEPS)  $(P_DEPS)  $(FSY_UPPER_DEPS)  $(C_DEPS)  $(SRC_DEPS)  $(JMP_UPPER_DEPS)  $(PP_DEPS)  $(SX_DEPS)  $(ASM_UPPER_DEPS)  $(SX_UPPER_DEPS)  $(OBJS)  $(SECONDARY_FLASH)  $(ASM_DEPS)  $(SREC)  $(S_UPPER_DEPS)  $(MAP) )
	-@ xargs -P 2 -s 32000 -t -a clean_file.tmp $(RM)
	-@$(RM) clean_file.tmp
	-$(RM)  RA8P1_Viewing_Screen_ESP32_Link.elf
	-@echo ' '

secondary-outputs: $(SECONDARY_FLASH) $(SECONDARY_SIZE)

